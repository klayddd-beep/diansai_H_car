<?xml version="1.0"?>
<robot name="car">
  <material name="blue">
    <color rgba="0.2 0.4 1.0 1" />
  </material>
  <material name="gray">
    <color rgba="0.2 0.2 0.2 1" />
  </material>

  <link name="laser_link">
    <visual>
      <origin xyz="0 0 0" />
      <geometry>
        <cylinder length="0.05" radius="0.03" />
      </geometry>
      <material name="gray" />
    </visual>
  </link>

  <link name="base_link" />

  <!-- 车雷达安装高度与飞车不同(扫描平面错开),z 按实车量取后修改 -->
  <joint name="laser_link_joint" type="fixed">
    <parent link="base_link" />
    <child link="laser_link" />
    <origin xyz="0 0 0.1" />
  </joint>

</robot>
